---
import "@/styles/custom-cursor.css";
---

<script is:inline>
  (function () {
    if (window.__customCursorInitialized) return;
    window.__customCursorInitialized = true;

    var MIN_WIDTH = 1024;
    var gPointer = null;
    var isEnabled = false;
    var isPressing = false;

    function createPointer() {
      if (gPointer) return;
      gPointer = document.createElement("div");
      gPointer.id = "g-pointer";
      document.body.appendChild(gPointer);
    }

    function removePointer() {
      if (!gPointer) return;
      gPointer.remove();
      gPointer = null;
    }

    function buildTransform(x, y) {
      var t = "translate(" + (x - 8.5) + "px, " + (y - 8.5) + "px)";
      if (isPressing) t += " scale(0.15)";
      return t;
    }

    function onMouseMove(e) {
      gPointer.style.transform = buildTransform(e.clientX, e.clientY);
    }

    function onMouseDown(e) {
      if (!isEnabled) return;
      isPressing = true;
      gPointer.style.transform = buildTransform(e.clientX, e.clientY);
    }

    function onMouseUp(e) {
      if (!isEnabled) return;
      isPressing = false;
      gPointer.style.transform = buildTransform(e.clientX, e.clientY);
      var el = document.createElement("div");
      el.className = "click-effect";
      el.style.left = (e.clientX - 6) + "px";
      el.style.top = (e.clientY - 6) + "px";
      el.style.width = "12px";
      el.style.height = "12px";
      document.body.appendChild(el);
      el.addEventListener("animationend", function () {
        el.remove();
      });
    }

    function onContextMenu(e) {
      e.preventDefault();
    }

    function onSelectStart(e) {
      e.preventDefault();
    }

    function activate() {
      if (window.innerWidth < MIN_WIDTH) return;
      if (isEnabled) return;

      document.documentElement.classList.add("custom-cursor-active");
      createPointer();
      document.addEventListener("mousemove", onMouseMove, { passive: true });
      document.addEventListener("mousedown", onMouseDown);
      document.addEventListener("mouseup", onMouseUp);
      document.addEventListener("contextmenu", onContextMenu);
      document.addEventListener("selectstart", onSelectStart);
      isEnabled = true;
    }

    function deactivate() {
      if (!isEnabled) return;
      document.documentElement.classList.remove("custom-cursor-active");
      removePointer();
      document.removeEventListener("mousemove", onMouseMove);
      document.removeEventListener("mousedown", onMouseDown);
      document.removeEventListener("mouseup", onMouseUp);
      document.removeEventListener("contextmenu", onContextMenu);
      document.removeEventListener("selectstart", onSelectStart);
      isEnabled = false;
    }

    function onResize() {
      if (window.innerWidth >= MIN_WIDTH) {
        if (!isEnabled) activate();
      } else {
        if (isEnabled) deactivate();
      }
    }

    window.addEventListener("resize", onResize, { passive: true });

    function setup() { onResize(); }

    function reinit() {
      deactivate();
      setTimeout(function () { activate(); }, 100);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setup);
    } else {
      setup();
    }

    window.addEventListener("astro:page-load", reinit);
    if (window.swup) {
      window.swup.hooks.on("content:replace", function () { reinit(); });
    }
  })();
</script>
